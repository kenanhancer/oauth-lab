# Copy to .env and adjust. pydantic-settings loads from .env automatically.

# Issuer URL — appears in JWT `iss` claim and discovery doc
OAUTH_LAB_ISSUER=http://localhost:8000

# Database — pick one. SQL backends are migrated with Alembic (`just migrate`);
# the app verifies schema-at-head on boot and refuses to start if you forgot.
OAUTH_LAB_DATABASE_URL=sqlite+aiosqlite:///./oauth_lab.db
# OAUTH_LAB_DATABASE_URL=postgresql+asyncpg://oauth:oauth@localhost:5432/oauth_lab
# OAUTH_LAB_DATABASE_URL=memory://                # in-process; lost on restart; no migrations

# Demo seeding (`just seed`) writes publicly-known credentials, so it refuses to
# run against a non-localhost issuer. Set true to override on a throwaway env.
# OAUTH_LAB_ALLOW_DEMO_SEED=false

# Token issuance
OAUTH_LAB_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_LAB_TOKEN_FORMAT=jwt                        # jwt | opaque

# JWT signing key (for development only — production uses a KMS or rotating JWKS)
OAUTH_LAB_JWT_PRIVATE_KEY_PATH=./keys/jwt_signing_key.pem
OAUTH_LAB_JWT_KEY_ID=dev-key-1

# Logging
OAUTH_LAB_LOG_LEVEL=INFO
